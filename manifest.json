{
  "manifest_version": 3,
  "name": "Read Later Tabs",
  "version": "0.1.1",
  "description": "A warm New Tab page that helps you triage your open tabs.",
  "permissions": ["tabs", "storage", "bookmarks", "alarms"],
  "host_permissions": ["https://*/*"],
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "background": { "service_worker": "src/background/service-worker.ts", "type": "module" },
  "action": { "default_popup": "src/popup/popup.html", "default_title": "Read Later Tabs" },
  "options_page": "src/options/options.html",
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
}
